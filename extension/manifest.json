{
  "manifest_version": 3,
  "name": "Domo",
  "version": "1.0.0",
  "description": "Personalize any website with CSS, HTML, and JS plugins — per URL, instantly.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "unlimitedStorage", "scripting", "tabs", "sidePanel", "webNavigation", "declarativeNetRequest"],
  "declarative_net_request": {
    "rule_resources": [
      { "id": "csp_bypass", "enabled": true, "path": "rules/csp.json" }
    ]
  },
  "side_panel": { "default_path": "sidepanel.html" },
  "action": {
    "default_title": "Domo",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "background": { "service_worker": "background.js" },
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"],
      "run_at": "document_start"
    }
  ],
  "commands": {
    "toggle-hide-mode": {
      "suggested_key": { "default": "Alt+H" },
      "description": "Toggle element hide mode"
    },
    "toggle-shortcuts-panel": {
      "suggested_key": { "default": "Alt+K" },
      "description": "Toggle keyboard shortcuts panel"
    }
  }
}
